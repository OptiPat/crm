# Indexation IA — complète .gitignore ; exclusions supplémentaires ci-dessous.

# Dépendances et builds (bruit, volume)
node_modules/
dist/
dist-ssr/
src-tauri/target/
release-artifacts/

# Données sensibles — ne jamais indexer
.env
.env.*
!.env.example
auth.json
*.key
*.pem
*.db
*.db-journal
*.db-wal
*.db-shm

# Sauvegardes / exports locaux
**/backups/
*.backup
*BACKUP*
*.xlsx

# Logs
*.log
logs/
